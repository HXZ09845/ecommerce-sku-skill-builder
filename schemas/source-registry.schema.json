{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HXZ09845/ecommerce-sku-skill-builder/schemas/source-registry.schema.json",
  "title": "Ecommerce SKU Source Registry",
  "type": "object",
  "required": ["version", "last_updated", "policy", "sources"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "last_updated": { "type": "string", "minLength": 1 },
    "policy": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "path",
          "privacy_level",
          "status",
          "includes",
          "excludes",
          "verified_on"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "privacy_level": { "type": "string", "enum": ["public", "anonymized"] },
          "status": { "type": "string", "enum": ["included", "pending", "deprecated"] },
          "includes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "excludes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "verified_on": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
