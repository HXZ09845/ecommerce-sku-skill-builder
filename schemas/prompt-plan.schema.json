{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HXZ09845/ecommerce-sku-skill-builder/schemas/prompt-plan.schema.json",
  "title": "Ecommerce SKU Prompt Plan",
  "type": "object",
  "required": ["project", "units", "reference_materials", "take_review"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": ["id", "format", "style"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 }
      }
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "duration", "proof_target", "one_visible_beat", "stop_when"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^U[-A-Za-z0-9_]*$" },
          "type": { "type": "string", "enum": ["A", "A-in", "A-out", "A+B", "B"] },
          "duration": { "type": "string", "minLength": 1 },
          "proof_target": { "type": "string", "minLength": 1 },
          "one_visible_beat": { "type": "string", "minLength": 1 },
          "stop_when": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reference_materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ref", "priority", "role", "controls", "does_not_control"],
        "additionalProperties": true,
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "pattern": "^P[0-3]$" },
          "role": { "type": "string", "minLength": 1 },
          "controls": { "type": "string", "minLength": 1 },
          "does_not_control": { "type": "string", "minLength": 1 }
        }
      }
    },
    "take_review": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["unit", "accept_criteria", "common_failure", "first_repair_variable"],
        "additionalProperties": true,
        "properties": {
          "unit": { "type": "string", "minLength": 1 },
          "accept_criteria": { "type": "string", "minLength": 1 },
          "common_failure": { "type": "string", "minLength": 1 },
          "first_repair_variable": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
